{
  "name": "bip",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "bip": "./src/cli.ts"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "verify:example": "bun run src/cli.ts verify examples/counter.ts --out generated",
    "verify:core": "bun run src/cli.ts verify-core examples/basic-site.tscore.ts --out generated/tscore",
    "scan:example": "bun run src/cli.ts scan ../reyneill",
    "test:tscore": "bun run scripts/check-tscore-validation.ts"
  },
  "dependencies": {
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.3"
  }
}
